<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    tools:context=".EditMedicineActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Edit Medicine"
                android:textColor="@color/text_dark_navy"
                android:textSize="18sp"
                android:textStyle="bold" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/btnSaveChanges"
        app:layout_constraintTop_toBottomOf="@+id/appBarLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Basic Information Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/StandardCardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Basic Information"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Medicine Name"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etMedicineName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Medicine Name"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Manufacturer"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etManufacturer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Manufacturer"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Category"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etCategory"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Category"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Current Quantity"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etQuantity"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Quantity"
                        android:inputType="number"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dosage Information Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/StandardCardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dosage Information"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Dosage Instructions"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etDosage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:gravity="top"
                        android:hint="e.g. 500mg - Take 1 tablet twice daily"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:padding="16dp"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Product Details Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/StandardCardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Details"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Expiry Date"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etExpiryDate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:focusable="false"
                        android:hint="Select Date"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Batch Number"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etBatchNumber"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Batch Number"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Images Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/StandardCardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Images"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Tablet Image -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Tablet Image"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivTabletImage"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="8dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_camera"
                        app:shapeAppearanceOverlay="@style/RoundedShapeAppearance" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChangeTabletImage"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Change Tablet Image"
                        android:textAllCaps="false"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_camera"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"
                        app:iconTint="@color/text_soft_grey"
                        app:strokeColor="#E5E7EB" />

                    <!-- Front Image -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Package Front Image"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivFrontImage"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="8dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_camera"
                        app:shapeAppearanceOverlay="@style/RoundedShapeAppearance" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChangeFrontImage"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Change Front Image"
                        android:textAllCaps="false"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_camera"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"
                        app:iconTint="@color/text_soft_grey"
                        app:strokeColor="#E5E7EB" />

                    <!-- Back Image -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Package Back Image"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivBackImage"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="8dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_camera"
                        app:shapeAppearanceOverlay="@style/RoundedShapeAppearance" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChangeBackImage"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:text="Change Back Image"
                        android:textAllCaps="false"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_camera"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"
                        app:iconTint="@color/text_soft_grey"
                        app:strokeColor="#E5E7EB" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveChanges"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:backgroundTint="@color/btn_blue"
        android:text="Save Changes"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/white"
        android:elevation="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">
                <ImageView
                    android:id="@+id/ivNavHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_soft_grey"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navScan"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">
                <ImageView
                    android:id="@+id/ivNavScan"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_soft_grey"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navIdentify"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">
                <ImageView
                    android:id="@+id/ivNavIdentify"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Identify"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_soft_grey"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReminders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">
                <ImageView
                    android:id="@+id/ivNavReminders"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reminders"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_soft_grey"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">
                <ImageView
                    android:id="@+id/ivNavProfile"
                    android:layout_width="24dp"
                    android:layout_height="24dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_soft_grey"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

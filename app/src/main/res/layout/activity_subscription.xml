<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFDFF"
    tools:context=".SubscriptionActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- App Icon -->
            <ImageView
                android:id="@+id/iv_app_icon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="32dp"
                android:src="@mipmap/ic_launcher"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- App Name -->
            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:text="scanmyPills"
                android:textColor="@color/text_dark_navy"
                android:textSize="32sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_app_icon" />

            <!-- Premium Tag -->
            <TextView
                android:id="@+id/tv_premium_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_category_tag"
                android:backgroundTint="#EEF2FF"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp"
                android:text="PREMIUM"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_app_name" />

            <!-- Description -->
            <TextView
                android:id="@+id/tv_description"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Unlock premium features to manage your medicines smarter and never miss a dose"
                android:textColor="@color/text_soft_grey"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_premium_tag" />

            <!-- Ad-Free Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ad_free"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/tv_description">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_ad_free"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chart"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#F59E0B" />

                    <TextView
                        android:id="@+id/tv_ad_free_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Ad-Free Experience"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="16sp"
                        app:layout_constraintEnd_toStartOf="@+id/iv_check_1"
                        app:layout_constraintStart_toEndOf="@id/iv_ad_free"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_ad_free_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="8dp"
                        android:text="No interruptions while tracking attendance"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@+id/iv_check_1"
                        app:layout_constraintStart_toEndOf="@id/iv_ad_free"
                        app:layout_constraintTop_toBottomOf="@id/tv_ad_free_title" />

                    <ImageView
                        android:id="@+id/iv_check_1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#10B981" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI Scan Priority Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_ai_scan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/card_ad_free">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_ai_scan"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_brain"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#3B82F6" />

                    <TextView
                        android:id="@+id/tv_ai_scan_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="AI Scan Priority"
                        android:textColor="@color/text_dark_navy"
                        android:textSize="16sp"
                        app:layout_constraintEnd_toStartOf="@+id/iv_check_2"
                        app:layout_constraintStart_toEndOf="@id/iv_ai_scan"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_ai_scan_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="8dp"
                        android:text="Experience faster and more accurate medicine scanning"
                        android:textColor="@color/text_soft_grey"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@+id/iv_check_2"
                        app:layout_constraintStart_toEndOf="@id/iv_ai_scan"
                        app:layout_constraintTop_toBottomOf="@id/tv_ai_scan_title" />

                    <ImageView
                        android:id="@+id/iv_check_2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#10B981" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Price Card -->
            <LinearLayout
                android:id="@+id/layout_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_premium_card_gradient"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/card_ai_scan">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Premium Plan"
                    android:textColor="#E0E7FF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-black"
                    android:text="₹99 / month"
                    android:textColor="@android:color/white"
                    android:textSize="24sp" />

            </LinearLayout>

            <!-- Start Premium Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_premium"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_subscribe_button"
                android:fontFamily="sans-serif-black"
                android:text="Start Premium"
                android:textAllCaps="false"
                android:textColor="@color/text_dark_navy"
                android:textSize="18sp"
                app:layout_constraintTop_toBottomOf="@id/layout_price" />

            <!-- Maybe Later Button -->
            <TextView
                android:id="@+id/btn_maybe_later"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:padding="8dp"
                android:text="Maybe later"
                android:textColor="@color/text_soft_grey"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_premium" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
